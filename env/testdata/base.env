# -----------------------------------------------
# base.env — base environment configuration
# -----------------------------------------------

# Application
APP_NAME=lx
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=true
APP_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lxdb
DB_USER=admin
DB_PASSWORD=secret

# Quoted values
GREETING="hello world"
SINGLE_QUOTED='single quoted value'

# Inline comments should be stripped
STRIPPED=value # this comment should be removed

# Quoted value containing hash — hash must NOT be stripped
TOKEN="abc#123"

# Special characters in value
SPECIAL=p@ssw0rd!

# Empty value
EMPTY_VAR=

# Value with spaces inside quotes
DESCRIPTION="this is a description"

